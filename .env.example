## Public (browser-exposed) vars
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

## Server-only vars (API routes / server actions)
# Pick ONE provider (or set both and XAI wins if both are set)
XAI_API_KEY=
XAI_MODEL=grok-4-mini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

## Copy to .env.local and fill values.
##
## Public (safe to expose to browser)
NEXT_PUBLIC_SITE_URL=https://portfollio-jp.vercel.app

## Server-only (do NOT expose publicly)
## Optional: enables real AI responses for /api/chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

## Optional: xAI Grok (preferred for this portfolio chat)
XAI_API_KEY=
XAI_MODEL=grok-4-mini

## Contact form email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

